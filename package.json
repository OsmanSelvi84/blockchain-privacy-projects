{
  "name": "smart-city-energy-trade",
  "version": "1.0.0",
  "description": "Privacy-preserving P2P energy netting for a smart-city microgrid",
  "scripts": {
    "compile-contracts": "truffle compile",
    "migrate-contracts": "truffle migrate",
    "migrate-contracts-ganache": "truffle migrate --reset --network ganache",
    "migrate-contracts-authority": "truffle migrate --reset --network authority --f 2",
    "migrate-contracts-authority-fast": "truffle migrate --reset --network authority --f 2 --compile-none",
    "test-netting": "mocha ./test/netting/*.js",
    "test": "yarn test-netting",
    "test-contracts": "truffle test ./test/contracts/* --compile-none",
    "parity-reference": "node scripts/compare-reference-settlement.js",
    "debug-settlement": "node scripts/debug-settlement.js",
    "check-ned": "node scripts/check-ned-prereqs.js",
    "check-validators": "node scripts/check-validators.js",
    "clear-demo": "node scripts/clear-demo-state.js",
    "run-netting": "node ./netting-service/index.js -i 60000",
    "run-gateway-h1": "node ./household-gateway/index.js -p 3002 -a 0x00aa39d30f0d20ff03a22ccfc30b7efbfca597c2 -P node1 -n authority_1",
    "run-gateway-h2": "node ./household-gateway/index.js -p 3003 -a 0x002e28950558fbede1a9675cb113f0bd20912019 -P node2 -n authority_2",
    "setup-zokrates": "./scripts/setup_zokrates.sh",
    "generate-zok-circuit": "node zk/zoKratesCodeGenerator.js",
    "update-contract-bytecodes": "yarn compile-contracts && node ./scripts/update-contract-bytecodes.js"
  },
  "dependencies": {
    "bn.js": "4.11.8",
    "chalk": "^2.4.2",
    "commander": "^2.20.0",
    "cors": "^2.8.5",
    "express": "^4.16.4",
    "js-sha256": "0.9.0",
    "mongodb": "3.3.2",
    "request-promise": "^4.2.4",
    "shelljs": "^0.8.3",
    "web3": "1.2.1"
  },
  "devDependencies": {
    "@gnosis.pm/mock-contract": "3.0.7",
    "babel-runtime": "6.26.0",
    "chai": "^4.2.0",
    "chai-bn": "^0.1.1",
    "ganache-cli": "6.7.0",
    "mocha": "^6.1.4",
    "openzeppelin-solidity": "2.2.0",
    "openzeppelin-test-helpers": "0.3.2",
    "solc": "0.5.17",
    "truffle": "5.1.67"
  },
  "engines": {
    "node": ">=10 <=20"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
